# Copy to .env and fill in. .env is gitignored — never commit real tokens/keys.

# ── LLM (OpenAI-compatible, e.g. local vLLM / qwen) ──────────────────────────
ASSISTANT_LLM_BASE_URL=http://YOUR_LLM_HOST:6008/v1
ASSISTANT_LLM_API_KEY=changeme
ASSISTANT_LLM_MODEL=chat

# ── Project business platform (RuoYi prod-api) — device/records/alarm/event ──
# Bearer token is short-lived (server-side TTL); refresh when control calls return 认证失败.
ASSISTANT_PROJECT_API_BASE_URL=http://YOUR_BACKEND_HOST:11000/prod-api/project
ASSISTANT_PROJECT_API_BEARER_TOKEN=
ASSISTANT_PROJECT_API_DEFAULT_SYSTEM_NO=kt
ASSISTANT_PROJECT_API_SYSTEM_NO_BY_DEVICE_TYPE=空调:kt,空调机组:kt,电梯:dt,照明:zm,消防:xf,停车:tc,门禁:mj,冷量:ll,能耗:ll
ASSISTANT_PROJECT_API_TIMEOUT_SECONDS=12

# ── Control execution mode ──────────────────────────────────────────────────
# simulated (default): never issues real deviceCtrl, only confirms + reads back.
# real: issues real deviceCtrl — only enable once the backend exposes commandId/idempotency.
HARNESS_CONTROL_EXECUTION=simulated

# ── Knowledge / RAG (harness_rag) ───────────────────────────────────────────
# HARNESS_RAG_LIVE=0 forces the Fake retriever (offline demo). Unset/anything-else = real RAG.
HARNESS_RAG_LIVE=
ASSISTANT_EMBEDDING_BASE_URL=http://YOUR_RAG_HOST:6009/v1
ASSISTANT_EMBEDDING_API_KEY=changeme
ASSISTANT_EMBEDDING_MODEL=qwen3-embedding
ASSISTANT_EMBEDDING_DIMENSIONS=1024
ASSISTANT_RERANKER_BASE_URL=http://YOUR_RAG_HOST:6010
ASSISTANT_RERANKER_API_KEY=changeme
ASSISTANT_RERANKER_MODEL=qwen3-reranker
ASSISTANT_RERANKER_ENDPOINT=score
ASSISTANT_MILVUS_URI=http://YOUR_RAG_HOST:19530
ASSISTANT_MILVUS_COLLECTION=knowledge_chunks

# ── Optional persistent stores (default: in-memory) ─────────────────────────
# SPA_STORAGE__REDIS_URL=redis://YOUR_HOST:6379/0
# SPA_STORAGE__POSTGRES_DSN=postgresql://user:pass@YOUR_HOST:5432/dbname
